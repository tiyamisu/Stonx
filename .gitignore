# ============================================================
# StonX — .gitignore
# Covers: Java/Maven backend + React/Vite/Node.js frontend
# ============================================================

# ── Java / Maven ────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# Maven wrapper
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ── Node.js / npm ───────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ── Vite / React build output ───────────────────────────────
dist/
dist-ssr/
*.local
.vite/

# ── Environment variables (never commit secrets!) ───────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── IDE / Editor files ──────────────────────────────────────
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse
.classpath
.project
.settings/
.factorypath
bin/

# VS Code
.vscode/
*.code-workspace

# NetBeans
nbproject/
nbbuild/
nbdist/
.nb-gradle/

# ── OS generated files ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Application generated data ──────────────────────────────
data/
*.dat
classpath.txt

# ── Test coverage ───────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Misc ────────────────────────────────────────────────────
.cache/
.parcel-cache/
*.tsbuildinfo
